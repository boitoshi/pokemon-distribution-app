---
import Layout from '../../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

export async function getStaticPaths() {
    const jsonPath = join(process.cwd(), 'public', 'pokemon.json');
    const data = JSON.parse(readFileSync(jsonPath, 'utf-8'));

    return data.map((pokemon: any) => ({
        params: { id: pokemon.managementId },
        props: { pokemon, allData: data },
    }));
}

interface PokemonData {
    managementId: string;
    pokemonName: string;
    shiny?: string;
    dexNo: number;
    generation: number;
    game: string;
    region?: string;
    eventName: string;
    distributionMethod: string;
    distributionLocation: string;
    startDate: string;
    endDate?: string;
    ot?: string | { JPN?: string; ENG?: string; SPA?: string; FRE?: string; GER?: string; ITA?: string; KOR?: string; CHS?: string; CHT?: string; SPA_EU?: string; SPA_LA?: string };
    trainerId?: string | number;
    ball?: string;
    level?: number;
    ability?: string;
    nature?: string;
    gigantamax?: string;
    teraType?: string;
    alpha?: string;
    heldItem?: string;
    ivs?: string | { hp?: number; atk?: number; def?: number; spa?: number; spd?: number; spe?: number };
    evs?: string;
    moves?: string[];
    ribbons?: string[];
    move1?: string;
    move2?: string;
    move3?: string;
    move4?: string;
    ribbon1?: string;
    ribbon2?: string;
    ribbon3?: string;
    specialMoves?: string;
    password?: string;
    notes?: string;
    postUrl?: string;
}

interface Props {
    pokemon: PokemonData;
    allData: PokemonData[];
}

const { pokemon, allData } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

// baseUrlの末尾にスラッシュを追加
const normalizedBaseUrl = baseUrl.endsWith('/') ? baseUrl : baseUrl + '/';

// 関連ポケモンを取得（同じポケモンの他の配信）
const samePokemonDistributions = allData
    .filter(p => p.dexNo === pokemon.dexNo && p.managementId !== pokemon.managementId)
    .sort((a, b) => (b.startDate || '').localeCompare(a.startDate || ''))
    .slice(0, 5);

// 同じイベントの他のポケモン
const sameEventPokemon = allData
    .filter(p => p.eventName === pokemon.eventName && p.managementId !== pokemon.managementId)
    .sort((a, b) => (a.dexNo || 0) - (b.dexNo || 0))
    .slice(0, 5);

// 同じ地域の配信（地域がある場合のみ）
const sameRegionDistributions = pokemon.region
    ? allData
        .filter(p => p.region === pokemon.region && p.managementId !== pokemon.managementId)
        .sort((a, b) => (b.startDate || '').localeCompare(a.startDate || ''))
        .slice(0, 5)
    : [];

// 画像URL
const isDev = import.meta.env.DEV;
const assetBase = isDev
    ? '/distribution/images'
    : 'https://www.pokebros.net/wp-content/uploads/pokemon-assets';
const imageBaseUrl = `${assetBase}/pokemon/pokedex`;
const ballImageBaseUrl = `${assetBase}/balls`;
const ribbonImageBaseUrl = `${assetBase}/ribbons`;
const markImageBaseUrl = `${assetBase}/marks`;

function getPokemonImageUrl(pokemon: PokemonData) {
    const dexNo = String(pokemon.dexNo).padStart(4, '0');
    const name = pokemon.gigantamax
        ? `キョダイマックス${pokemon.pokemonName}`
        : pokemon.pokemonName;
    return `${imageBaseUrl}/${dexNo}_${name}.png`;
}

function isMarkName(name: string) {
    return name.endsWith('あかし');
}

function getRibbonImageUrl(name: string) {
    return isMarkName(name)
        ? `${markImageBaseUrl}/${name}.png`
        : `${ribbonImageBaseUrl}/${name}.png`;
}

function getBallImageUrl(name: string) {
    return `${ballImageBaseUrl}/${name}.png`;
}

// 日付フォーマット
function formatDate(dateStr?: string) {
    if (!dateStr) return '';
    const date = new Date(dateStr);
    return `${date.getFullYear()}/${(date.getMonth() + 1).toString().padStart(2, '0')}/${date.getDate().toString().padStart(2, '0')}`;
}

// 配信中かどうか
function isDistributionActive(endDate?: string) {
    if (!endDate) return true;
    const now = new Date();
    const end = new Date(endDate);
    return now <= end;
}

// ゲーム略称マッピング
const gameShortNames: Record<string, string> = {
    "ソード, シールド": "剣盾",
    "ブリリアントダイヤモンド, シャイニングパール": "BDSP",
    "Pokémon LEGENDS アルセウス": "LA",
    "スカーレット, バイオレット": "SV",
    "Pokémon LEGENDS Z-A": "ZA",
    // 第5世代
    "ブラック, ホワイト": "BW",
    "ブラック2, ホワイト2": "BW2",
    "ブラック, ホワイト, ブラック2, ホワイト2": "BW/BW2",
    // 第6世代
    "X, Y": "XY",
    "オメガルビー, アルファサファイア": "ORAS",
    "X, Y, オメガルビー, アルファサファイア": "XY/ORAS",
    // 第7世代
    "サン, ムーン": "SM",
    "ウルトラサン, ウルトラムーン": "USUM",
    "サン, ムーン, ウルトラサン, ウルトラムーン": "SM/USUM",
    "ピカブイ": "ピカブイ",
    "ピカチュウ（Let's Go）": "ピカブイ",
    "イーブイ（Let's Go）": "ピカブイ"
};
function getGameDisplayName(game: string) {
    const short = gameShortNames[game];
    return short ? `${short}（${game}）` : game;
}

// ゲームタイプ判定
function isSwSh(game: string) {
    return game && (game.includes('ソード') || game.includes('シールド'));
}

function isSV(game: string) {
    return game && (game.includes('スカーレット') || game.includes('バイオレット'));
}

function isLegendsGame(game: string) {
    return game && (game.includes('アルセウス') || game.includes('Z-A') || game === 'ZA');
}

// OT表示用
function formatOT(ot?: string | { JPN?: string; ENG?: string; SPA?: string; FRE?: string; GER?: string; ITA?: string; KOR?: string; CHS?: string; CHT?: string; SPA_EU?: string; SPA_LA?: string }) {
    if (!ot) return '?';
    if (typeof ot === 'object') {
        const parts = [];
        if (ot.JPN) parts.push(`日: ${ot.JPN}`);
        if (ot.ENG) parts.push(`英: ${ot.ENG}`);
        if (ot.SPA) parts.push(`西: ${ot.SPA}`);
        if (ot.SPA_EU) parts.push(`欧西: ${ot.SPA_EU}`);
        if (ot.SPA_LA) parts.push(`米西: ${ot.SPA_LA}`);
        if (ot.FRE) parts.push(`仏: ${ot.FRE}`);
        if (ot.GER) parts.push(`独: ${ot.GER}`);
        if (ot.ITA) parts.push(`伊: ${ot.ITA}`);
        if (ot.KOR) parts.push(`韓: ${ot.KOR}`);
        if (ot.CHS) parts.push(`簡中: ${ot.CHS}`);
        if (ot.CHT) parts.push(`繁中: ${ot.CHT}`);
        return parts.join(' / ') || '?';
    }
    return ot;
}

// 個体値表示用
function formatIVs(ivs?: string | { hp?: number; atk?: number; def?: number; spa?: number; spd?: number; spe?: number }) {
    if (!ivs) return null;
    if (typeof ivs === 'string') {
        return /^\d+V$/.test(ivs) ? `${ivs}固定` : ivs;
    }
    const labels: [keyof typeof ivs, string][] = [['hp', 'H'], ['atk', 'A'], ['def', 'B'], ['spa', 'C'], ['spd', 'D'], ['spe', 'S']];
    return labels
        .filter(([key]) => ivs[key] !== undefined)
        .map(([key, label]) => `${label}:${ivs[key]}`)
        .join(' / ');
}

// 技の配列を取得
const moves = pokemon.moves && Array.isArray(pokemon.moves)
    ? pokemon.moves.filter(m => m && m !== '')
    : [pokemon.move1, pokemon.move2, pokemon.move3, pokemon.move4].filter(m => m && m !== '');

// リボンの配列を取得
const ribbons = pokemon.ribbons && Array.isArray(pokemon.ribbons)
    ? pokemon.ribbons.filter(r => r && r !== '')
    : [pokemon.ribbon1, pokemon.ribbon2, pokemon.ribbon3].filter(r => r && r !== '');

const isActive = isDistributionActive(pokemon.endDate);
const statusClass = isActive ? 'status-active' : 'status-ended';
const statusText = isActive ? '配信中' : '終了';

// OGP用
const pageTitle = `${pokemon.pokemonName} - ${pokemon.eventName} | 配信ポケモン検索`;
const pageDescription = `${pokemon.pokemonName}の配信情報。${pokemon.eventName}（${formatDate(pokemon.startDate)}〜${pokemon.endDate ? formatDate(pokemon.endDate) : '終了日未定'}）。配信方法: ${pokemon.distributionMethod}`;
const ogImage = getPokemonImageUrl(pokemon);
const canonicalUrl = `https://www.pokebros.net/distribution/pokemon/${pokemon.managementId}`;
---

<Layout
    title={pageTitle}
    description={pageDescription}
    ogImage={ogImage}
    ogType="article"
    canonicalUrl={canonicalUrl}
>
    <header>
        <div class="header-content">
            <div class="header-left">
                <h1>配信ポケモン検索データベース</h1>
                <p>配信ポケモンを検索できます</p>
            </div>
        </div>
    </header>

    <div class="breadcrumb">
        <a href={baseUrl}>トップ</a> &gt; <span>{pokemon.pokemonName}</span>
    </div>

    <div class="pokemon-detail">
        <div class="detail-header">
            <div class="detail-image-container">
                <img
                    class="detail-pokemon-image"
                    src={getPokemonImageUrl(pokemon)}
                    alt={pokemon.pokemonName}
                    loading="lazy"
                >
            </div>
            <div class="detail-header-content">
                <h2>
                    <span class="detail-pokemon-name">{pokemon.pokemonName}</span>
                    {pokemon.shiny && pokemon.shiny !== '' && <span class="shiny-indicator" title="色違い">✨</span>}
                </h2>
                <div class="detail-dex-number">No.{String(pokemon.dexNo).padStart(3, '0')}</div>
                <div class="detail-badges">
                    {pokemon.gigantamax && pokemon.gigantamax !== '' && isSwSh(pokemon.game) && (
                        <span class="text-badge">キョダイマックス可</span>
                    )}
                    {pokemon.teraType && pokemon.teraType !== '' && isSV(pokemon.game) && (
                        <span class="tera-type-badge">テラスタイプ: {pokemon.teraType}</span>
                    )}
                    {pokemon.alpha && pokemon.alpha !== '' && isLegendsGame(pokemon.game) && (
                        <span class="text-badge">オヤブン</span>
                    )}
                </div>
            </div>
        </div>

        <div class="detail-grid">
            <div class="detail-section">
                <h3>基本情報</h3>
                <div class="info-row">
                    <div class="info-label">世代:</div>
                    <div class="info-value">
                        <span class={`generation-badge gen-${pokemon.generation}`}>第{pokemon.generation}世代</span>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-label">イベント:</div>
                    <div class="info-value">{pokemon.eventName}</div>
                </div>
                <div class="info-row">
                    <div class="info-label">配布期間:</div>
                    <div class="info-value">
                        {formatDate(pokemon.startDate)} 〜 {pokemon.endDate ? formatDate(pokemon.endDate) : '終了日未定'}
                        <span class={`status-badge ${statusClass}`}>{statusText}</span>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-label">配信方法:</div>
                    <div class="info-value">{pokemon.distributionMethod}</div>
                </div>
                {pokemon.password && (
                    <div class="info-row">
                        <div class="info-label">あいことば:</div>
                        <div class="info-value">
                            <span class="modal-password">{pokemon.password}</span>
                        </div>
                    </div>
                )}
                <div class="info-row">
                    <div class="info-label">配信場所:</div>
                    <div class="info-value">{pokemon.distributionLocation}</div>
                </div>
                <div class="info-row">
                    <div class="info-label">ゲーム:</div>
                    <div class="info-value">{getGameDisplayName(pokemon.game)}</div>
                </div>
                {pokemon.region && (
                    <div class="info-row">
                        <div class="info-label">地域:</div>
                        <div class="info-value">{pokemon.region}</div>
                    </div>
                )}
            </div>

            <div class="detail-section">
                <h3>ステータス</h3>
                <div class="info-row">
                    <div class="info-label">レベル:</div>
                    <div class="info-value">{pokemon.level || '?'}</div>
                </div>
                <div class="info-row">
                    <div class="info-label">特性:</div>
                    <div class="info-value">{pokemon.ability || '?'}</div>
                </div>
                {pokemon.nature && (
                    <div class="info-row">
                        <div class="info-label">性格:</div>
                        <div class="info-value">{pokemon.nature}</div>
                    </div>
                )}
                <div class="info-row">
                    <div class="info-label">ボール:</div>
                    <div class="info-value">{pokemon.ball ? <Fragment><img src={getBallImageUrl(pokemon.ball)} alt="" class="ball-icon-img" onerror="this.style.display='none';this.nextElementSibling.style.display='inline'" /><span style="display:none">⚪</span> {pokemon.ball}</Fragment> : '?'}</div>
                </div>
                {pokemon.teraType && pokemon.teraType !== '' && isSV(pokemon.game) && (
                    <div class="info-row">
                        <div class="info-label">テラスタイプ:</div>
                        <div class="info-value">{pokemon.teraType}</div>
                    </div>
                )}
                {pokemon.heldItem && pokemon.heldItem !== '' && (
                    <div class="info-row">
                        <div class="info-label">持ち物:</div>
                        <div class="info-value"><span class="item-tag">{pokemon.heldItem}</span></div>
                    </div>
                )}
                {pokemon.ivs && (
                    <div class="info-row">
                        <div class="info-label">個体値:</div>
                        <div class="info-value">{formatIVs(pokemon.ivs)}</div>
                    </div>
                )}
                {pokemon.evs && (
                    <div class="info-row">
                        <div class="info-label">努力値:</div>
                        <div class="info-value">{pokemon.evs}</div>
                    </div>
                )}
            </div>

            <div class="detail-section detail-wide">
                <h3>トレーナー情報</h3>
                <div class="info-row">
                    <div class="info-label">親名:</div>
                    <div class="info-value">{formatOT(pokemon.ot)}</div>
                </div>
                {pokemon.trainerId && (
                    <div class="info-row">
                        <div class="info-label">ID:</div>
                        <div class="info-value">{pokemon.trainerId}</div>
                    </div>
                )}
            </div>

            {moves.length > 0 && (
                <div class="detail-section detail-wide">
                    <h3>わざ</h3>
                    <div class="moves-list">
                        {moves.map((move: string) => (
                            <div class="move-item">{move}</div>
                        ))}
                    </div>
                </div>
            )}

            {ribbons.length > 0 && (
                <div class="detail-section detail-wide">
                    <h3>リボン</h3>
                    <div class="ribbons-list">
                        {ribbons.map((ribbon: string) => (
                            <span class="ribbon-icon"><img src={getRibbonImageUrl(ribbon)} alt="" onerror="this.style.display='none';this.nextElementSibling.style.display='inline'" /><span style="display:none">{isMarkName(ribbon) ? '🏅' : '🎀'}</span> {ribbon}</span>
                        ))}
                    </div>
                </div>
            )}

            {pokemon.notes && pokemon.notes !== '' && (
                <div class="detail-section detail-wide">
                    <h3>備考</h3>
                    <div class="notes-text">{pokemon.notes}</div>
                </div>
            )}

            <div class="detail-section detail-wide">
                <h3>シェア</h3>
                <div class="share-buttons">
                    <a
                        class="share-twitter share-btn"
                        href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(`${pokemon.pokemonName} - ${pokemon.eventName}`)}&url=${encodeURIComponent(canonicalUrl)}`}
                        target="_blank"
                        rel="noopener noreferrer"
                    >𝕏 ポスト</a>
                    <button class="share-copy share-btn" data-url={canonicalUrl}>🔗 URLコピー</button>
                </div>
            </div>

            {pokemon.postUrl && pokemon.postUrl !== '' && (
                <div class="detail-section detail-wide">
                    <a class="post-url-link" href={pokemon.postUrl} target="_blank" rel="noopener noreferrer">
                        詳細記事を見る
                    </a>
                </div>
            )}
        </div>

        <!-- 関連ポケモン -->
        {(samePokemonDistributions.length > 0 || sameEventPokemon.length > 0 || sameRegionDistributions.length > 0) && (
            <div class="related-section">
                <h3>関連する配信ポケモン</h3>

                {samePokemonDistributions.length > 0 && (
                    <div class="related-group">
                        <h4>🔄 {pokemon.pokemonName}の他の配信</h4>
                        <div class="related-list">
                            {samePokemonDistributions.map((p: PokemonData) => (
                                <a href={`${normalizedBaseUrl}pokemon/${p.managementId}`} class="related-card">
                                    <img
                                        class="related-image"
                                        src={getPokemonImageUrl(p)}
                                        alt={p.pokemonName}
                                        loading="lazy"
                                    />
                                    <div class="related-info">
                                        <div class="related-name">
                                            {p.pokemonName}
                                            {p.shiny && p.shiny !== '' && <span class="shiny-mark">✨</span>}
                                        </div>
                                        <div class="related-event">{p.eventName}</div>
                                        <div class="related-date">{formatDate(p.startDate)}</div>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </div>
                )}

                {sameEventPokemon.length > 0 && (
                    <div class="related-group">
                        <h4>🎪 「{pokemon.eventName}」の他のポケモン</h4>
                        <div class="related-list">
                            {sameEventPokemon.map((p: PokemonData) => (
                                <a href={`${normalizedBaseUrl}pokemon/${p.managementId}`} class="related-card">
                                    <img
                                        class="related-image"
                                        src={getPokemonImageUrl(p)}
                                        alt={p.pokemonName}
                                        loading="lazy"
                                    />
                                    <div class="related-info">
                                        <div class="related-name">
                                            {p.pokemonName}
                                            {p.shiny && p.shiny !== '' && <span class="shiny-mark">✨</span>}
                                        </div>
                                        <div class="related-dex">No.{String(p.dexNo).padStart(3, '0')}</div>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </div>
                )}

                {sameRegionDistributions.length > 0 && (
                    <div class="related-group">
                        <h4>🌏 {pokemon.region}の他の配信</h4>
                        <div class="related-list">
                            {sameRegionDistributions.map((p: PokemonData) => (
                                <a href={`${normalizedBaseUrl}pokemon/${p.managementId}`} class="related-card">
                                    <img
                                        class="related-image"
                                        src={getPokemonImageUrl(p)}
                                        alt={p.pokemonName}
                                        loading="lazy"
                                    />
                                    <div class="related-info">
                                        <div class="related-name">
                                            {p.pokemonName}
                                            {p.shiny && p.shiny !== '' && <span class="shiny-mark">✨</span>}
                                        </div>
                                        <div class="related-event">{p.eventName}</div>
                                        <div class="related-date">{formatDate(p.startDate)}</div>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </div>
                )}
            </div>
        )}

        <div class="back-link">
            <a href={baseUrl} class="back-button">← 検索に戻る</a>
        </div>
    </div>
</Layout>

<style>
    .breadcrumb {
        background: white;
        padding: 10px 15px;
        border-radius: 6px;
        margin-bottom: 15px;
        font-size: 13px;
    }

    .breadcrumb a {
        color: #1976d2;
        text-decoration: none;
    }

    .breadcrumb a:hover {
        text-decoration: underline;
    }

    .pokemon-detail {
        background: white;
        border-radius: 8px;
        padding: 25px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    }

    .detail-header {
        display: flex;
        gap: 25px;
        margin-bottom: 25px;
        padding-bottom: 20px;
        border-bottom: 2px solid #f0f0f0;
        align-items: flex-start;
    }

    .detail-image-container {
        flex-shrink: 0;
        width: 150px;
        height: 150px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f5f5f5;
        border-radius: 12px;
        overflow: hidden;
    }

    .detail-pokemon-image {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .detail-header-content {
        flex: 1;
    }

    .detail-header-content h2 {
        font-size: 28px;
        color: #222;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .shiny-indicator {
        font-size: 24px;
        cursor: help;
    }

    .detail-dex-number {
        font-size: 20px;
        font-weight: 700;
        color: #1976d2;
        margin-bottom: 10px;
    }

    .detail-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-bottom: 25px;
    }

    .detail-section {
        background: #f9f9f9;
        padding: 20px;
        border-radius: 8px;
    }

    .detail-section h3 {
        font-size: 16px;
        color: #1a237e;
        margin-bottom: 15px;
        font-weight: 700;
        border-bottom: 2px solid #e0e0e0;
        padding-bottom: 10px;
    }

    .detail-wide {
        grid-column: 1 / -1;
    }

    .moves-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .move-item {
        background: #e8f5e9;
        color: #2e7d32;
        padding: 10px 15px;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 500;
    }

    .ribbons-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .notes-text {
        font-size: 14px;
        color: #666;
        line-height: 1.6;
    }

    .back-link {
        text-align: center;
