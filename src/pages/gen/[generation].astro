---
import Layout from '../../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

interface PokemonData {
    managementId: string;
    pokemonName: string;
    shiny?: string;
    dexNo: number;
    generation: number;
    game: string;
    region?: string;
    eventName: string;
    distributionMethod: string;
    distributionLocation?: string;
    startDate: string;
    endDate?: string;
    ot?: string | { JPN?: string; ENG?: string };
    gigantamax?: string;
    alpha?: string;
    teraType?: string;
    level?: number;
    ability?: string;
    nature?: string;
    heldItem?: string;
    notes?: string;
    postUrl?: string;
}

interface GenGuide {
    title?: string;
    hardware?: string;
    intro?: string;
    methods?: { name: string; description: string }[];
    notes?: string;
    externalUrl?: string;
}

export async function getStaticPaths() {
    const jsonPath = join(process.cwd(), 'public', 'pokemon.json');
    const data: PokemonData[] = JSON.parse(readFileSync(jsonPath, 'utf-8'));

    const guidesPath = join(process.cwd(), 'src', 'data', 'gen-guides.json');
    const guides: Record<string, GenGuide> = JSON.parse(readFileSync(guidesPath, 'utf-8'));

    // gen 1〜7 のみ対象（gen0 は特殊、gen8/9 は externalUrl）
    const targetGens = [1, 2, 3, 4, 5, 6, 7];

    const paths = targetGens
        .map((n) => {
            const entries = data.filter((p) => p.generation === n);
            if (entries.length === 0) return null;
            return {
                params: { generation: String(n) },
                props: {
                    entries,
                    guide: guides[String(n)] ?? null,
                    generation: n,
                },
            };
        })
        .filter(Boolean);

    return paths;
}

// ヘルパー関数（[id].astro から移植）
const isDev = import.meta.env.DEV;
const assetBase = isDev
    ? '/distribution/images'
    : 'https://www.pokebros.net/wp-content/uploads/pokemon-assets';
const imageBaseUrl = `${assetBase}/pokemon/pokedex`;

function getPokemonImageUrl(pokemon: PokemonData) {
    const dexNo = String(pokemon.dexNo).padStart(4, '0');
    const name = pokemon.gigantamax
        ? `キョダイマックス${pokemon.pokemonName}`
        : pokemon.pokemonName;
    return `${imageBaseUrl}/${dexNo}_${name}.png`;
}

function formatDate(dateStr?: string) {
    if (!dateStr) return '';
    const date = new Date(dateStr);
    return `${date.getFullYear()}/${(date.getMonth() + 1).toString().padStart(2, '0')}/${date.getDate().toString().padStart(2, '0')}`;
}

function isDistributionActive(endDate?: string) {
    if (!endDate) return true;
    const now = new Date();
    const end = new Date(endDate);
    return now <= end;
}

function isSwSh(game: string) {
    return game && (game.includes('ソード') || game.includes('シールド'));
}

function isLegendsGame(game: string) {
    return game && (game.includes('アルセウス') || game.includes('Z-A') || game === 'ZA');
}

interface Props {
    entries: PokemonData[];
    guide: GenGuide | null;
    generation: number;
}

const { entries, guide, generation } = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const normalizedBaseUrl = baseUrl.endsWith('/') ? baseUrl : baseUrl + '/';

// グルーピング: distributionMethod 別に分け、件数多い順 → 各グループ内 startDate 昇順
const groupMap = new Map<string, PokemonData[]>();
for (const p of entries) {
    const method = p.distributionMethod || '不明';
    if (!groupMap.has(method)) groupMap.set(method, []);
    groupMap.get(method)!.push(p);
}
// 各グループ内を startDate 昇順にソート
for (const [, arr] of groupMap) {
    arr.sort((a, b) => (a.startDate || '').localeCompare(b.startDate || ''));
}
// グループ自体を件数多い順にソート
const groups = [...groupMap.entries()].sort((a, b) => b[1].length - a[1].length);

// OGP
const genName = guide?.title ?? `第${generation}世代`;
const pageTitle = `${genName}の配信ポケモンまとめ | 配信ポケモン検索`;
const pageDescription = `${genName}（${guide?.hardware ?? ''}）の配信ポケモン${entries.length}件のまとめ。配信方法別に一覧で確認できます。`;
const canonicalUrl = `https://www.pokebros.net/distribution/gen/${generation}/`;
const ogImage = entries.length > 0 ? getPokemonImageUrl(entries[0]) : undefined;
---

<Layout
    title={pageTitle}
    description={pageDescription}
    canonicalUrl={canonicalUrl}
    ogImage={ogImage}
>
    <!-- ヘッダー行: breadcrumb + ダークモードトグル -->
    <header>
        <div class="gen-header">
            <div class="gen-breadcrumb">
                <a href={baseUrl}>トップ</a>
                <span class="breadcrumb-sep">&gt;</span>
                <span>{genName}</span>
            </div>
            <button id="toggleDarkMode" class="dark-mode-btn">🌙</button>
        </div>
    </header>

    <main class="gen-main">
        <h1 class="gen-title">{genName}の配信ポケモンまとめ</h1>

        {/* 解説セクション */}
        {guide?.intro && (
            <section class="gen-intro">
                <p class="gen-intro-text">{guide.intro}</p>
                {guide.hardware && (
                    <p class="gen-hardware">対象ハード: <strong>{guide.hardware}</strong></p>
                )}
            </section>
        )}

        {/* 配信方法別グループ */}
        {groups.map(([method, pokemons]) => {
            const methodDesc = guide?.methods?.find((m) => m.name === method)?.description ?? null;
            return (
                <section class="gen-group">
                    <h2 class="gen-group-title">
                        {method}
                        <span class="gen-group-count">（{pokemons.length}件）</span>
                    </h2>
                    {methodDesc && (
                        <p class="method-desc">{methodDesc}</p>
                    )}
                    <div class="gen-card-list">
                        {pokemons.map((p) => {
                            const active = isDistributionActive(p.endDate);
                            return (
                                <a
                                    class={`gen-card${active ? ' gen-card--active' : ''}`}
                                    href={`${normalizedBaseUrl}pokemon/${p.managementId}`}
                                >
                                    <img
                                        class="gen-card-image"
                                        src={getPokemonImageUrl(p)}
                                        alt={p.pokemonName}
                                        loading="lazy"
                                        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                                    />
                                    <span class="gen-card-image-fallback" style="display:none">⚪</span>
                                    <div class="gen-card-body">
                                        <div class="gen-card-name">
                                            {p.pokemonName}
                                            {p.shiny && p.shiny !== '' && (
                                                <span class="badge badge--shiny" title="色違い">✨</span>
                                            )}
                                            {p.gigantamax && p.gigantamax !== '' && isSwSh(p.game) && (
                                                <span class="badge badge--gigantamax">キョダイ</span>
                                            )}
                                            {p.alpha && p.alpha !== '' && isLegendsGame(p.game) && (
                                                <span class="badge badge--alpha">オヤブン</span>
                                            )}
                                        </div>
                                        <div class="gen-card-event">{p.eventName}</div>
                                        <div class="gen-card-date">
                                            {formatDate(p.startDate)}〜{p.endDate ? formatDate(p.endDate) : ''}
                                        </div>
                                        {p.region && (
                                            <div class="gen-card-region">{p.region}</div>
                                        )}
                                    </div>
                                </a>
                            );
                        })}
                    </div>
                </section>
            );
        })}

        {/* フッター */}
        <div class="page-footer">
            <a href={baseUrl} class="footer-search-link">すべての配信ポケモンを検索する →</a>
        </div>
    </main>
</Layout>

<style>
    /* ヘッダー */
    .gen-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px;
        background: var(--color-primary);
    }

    .gen-breadcrumb {
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    .gen-breadcrumb a {
        color: #fff;
        text-decoration: none;
        padding: 4px 10px;
        background: rgba(0, 0, 0, 0.15);
        border-radius: 6px;
    }

    .gen-breadcrumb a:hover {
        background: rgba(0, 0, 0, 0.25);
        text-decoration: none;
    }

    .breadcrumb-sep {
        color: rgba(255, 255, 255, 0.7);
    }

    .gen-breadcrumb span:last-child {
        color: #fff;
        font-weight: 600;
    }

    .dark-mode-btn {
        background: none;
        border: none;
        font-size: 20px;
        cursor: pointer;
        padding: 4px;
    }

    /* メイン */
    .gen-main {
        max-width: 800px;
        margin: 0 auto;
        padding: 16px 12px 48px;
    }

    .gen-title {
        font-size: 22px;
        font-weight: bold;
        color: var(--color-text-primary);
        margin: 0 0 16px;
        padding-bottom: 10px;
        border-bottom: 3px solid var(--color-primary);
    }

    /* 解説セクション */
    .gen-intro {
        background: var(--color-bg-section);
        border-radius: 10px;
        padding: 14px 16px;
        margin-bottom: 24px;
    }

    .gen-intro-text {
        margin: 0 0 8px;
        font-size: 14px;
        line-height: 1.7;
        color: var(--color-text-primary);
    }

    .gen-hardware {
        margin: 0;
        font-size: 13px;
        color: var(--color-text-secondary);
    }

    /* グループ見出し */
    .gen-group {
        margin-bottom: 32px;
    }

    .gen-group-title {
        font-size: 18px;
        font-weight: bold;
        color: var(--color-text-primary);
        margin: 0 0 6px;
        padding: 8px 12px;
        background: var(--color-bg-section);
        border-left: 4px solid var(--color-primary);
        border-radius: 0 6px 6px 0;
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    .gen-group-count {
        font-size: 14px;
        font-weight: normal;
        color: var(--color-text-secondary);
    }

    .method-desc {
        font-size: 13px;
        color: var(--color-text-secondary);
        margin: 0 0 12px;
        padding: 8px 12px;
        border: 1px solid var(--color-border);
        border-radius: 6px;
        line-height: 1.6;
    }

    /* カード一覧 */
    .gen-card-list {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .gen-card {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 10px 12px;
        background: var(--color-bg-card);
        border: 2px solid var(--color-border-light);
        border-radius: 10px;
        text-decoration: none;
        color: inherit;
        transition: all 0.2s;
        width: calc(50% - 5px);
        box-sizing: border-box;
        box-shadow: 0 1px 4px var(--color-shadow);
    }

    .gen-card:hover {
        border-color: var(--color-accent);
        background: var(--color-primary-light);
        transform: translateY(-2px);
        box-shadow: 0 4px 10px var(--color-shadow-hover);
    }

    .gen-card--active {
        border-color: #22c55e;
    }

    .gen-card-image {
        width: 56px;
        height: 56px;
        object-fit: contain;
        background: var(--color-bg-section);
        border-radius: 8px;
        flex-shrink: 0;
    }

    .gen-card-image-fallback {
        display: none;
        width: 56px;
        height: 56px;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        background: var(--color-bg-section);
        border-radius: 8px;
        flex-shrink: 0;
    }

    .gen-card-body {
        flex: 1;
        min-width: 0;
    }

    .gen-card-name {
        font-weight: 700;
        font-size: 14px;
        color: var(--color-text-primary);
        display: flex;
        align-items: center;
        gap: 4px;
        flex-wrap: wrap;
        margin-bottom: 4px;
    }

    /* バッジ */
    .badge {
        font-size: 10px;
        padding: 1px 5px;
        border-radius: 4px;
        font-weight: 600;
        line-height: 1.5;
    }

    .badge--shiny {
        font-size: 13px;
    }

    .badge--gigantamax {
        background: #fbbf24;
        color: #78350f;
    }

    .badge--alpha {
        background: #a78bfa;
        color: #3b0764;
    }

    .gen-card-event {
        font-size: 12px;
        color: var(--color-text-secondary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 2px;
    }

    .gen-card-date {
        font-size: 11px;
        color: var(--color-text-muted);
    }

    .gen-card-region {
        font-size: 11px;
        color: var(--color-text-muted);
        margin-top: 2px;
    }

    /* フッター */
    .page-footer {
        margin-top: 40px;
        text-align: center;
        padding-top: 24px;
        border-top: 1px solid var(--color-border);
    }

    .footer-search-link {
        display: inline-block;
        padding: 10px 20px;
        background: var(--color-primary);
        color: #fff;
        border-radius: 8px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: opacity 0.2s;
    }

    .footer-search-link:hover {
        opacity: 0.85;
    }

    /* レスポンシブ */
    @media (max-width: 768px) {
        .gen-card {
            width: 100%;
        }

        .gen-title {
            font-size: 18px;
        }

        .gen-group-title {
            font-size: 16px;
        }
    }

    @media (max-width: 400px) {
        .gen-header {
            padding: 8px 12px;
        }

        .gen-breadcrumb {
            font-size: 12px;
        }
    }

    /* ダークモード上書き */
    body.dark-mode .gen-breadcrumb span:last-child {
        color: #fff;
    }

    body.dark-mode .gen-title {
        color: #f0f0f0;
    }

    body.dark-mode .gen-intro {
        background: #2a2a2a;
    }

    body.dark-mode .gen-intro-text {
        color: #e0e0e0;
    }

    body.dark-mode .gen-hardware {
        color: #aaa;
    }

    body.dark-mode .gen-group-title {
        background: #2a2a2a;
        color: #f0f0f0;
    }

    body.dark-mode .gen-group-count {
        color: #aaa;
    }

    body.dark-mode .method-desc {
        border-color: #444;
        color: #ccc;
    }

    body.dark-mode .gen-card {
        background: #1e1e1e;
        border-color: #3a3a3a;
    }

    body.dark-mode .gen-card:hover {
        background: #2a2a2a;
        border-color: var(--color-accent);
    }

    body.dark-mode .gen-card-image {
        background: #2a2a2a;
    }

    body.dark-mode .gen-card-name {
        color: #f0f0f0;
    }

    body.dark-mode .gen-card-event {
        color: #bbb;
    }

    body.dark-mode .gen-card-date,
    body.dark-mode .gen-card-region {
        color: #888;
    }

    body.dark-mode .page-footer {
        border-color: #444;
    }
</style>

<script>
    // ダークモード（timeline.astro の方式を踏襲）
    function initDarkMode() {
        if (localStorage.getItem('dark-mode') === 'true') {
            document.body.classList.add('dark-mode');
            const btn = document.getElementById('toggleDarkMode');
            if (btn) btn.textContent = '☀️';
        }
    }

    const toggleBtn = document.getElementById('toggleDarkMode');
    if (toggleBtn) {
        toggleBtn.addEventListener('click', () => {
            const isDark = document.body.classList.toggle('dark-mode');
            localStorage.setItem('dark-mode', String(isDark));
            toggleBtn.textContent = isDark ? '☀️' : '🌙';
        });
    }

    initDarkMode();
</script>
