---
import Layout from '../layouts/Layout.astro';
import SearchBox from '../components/SearchBox.astro';
import PokemonCard from '../components/PokemonCard.astro';

const baseUrl = import.meta.env.BASE_URL;
---

<Layout title="配信ポケモン検索データベース">
    <header>
        <div class="header-content">
            <div class="header-left">
                <h1>配信ポケモン検索データベース</h1>
                <p>配信ポケモンを検索できます</p>
            </div>
            <div class="header-right">
                <a href={`${baseUrl}timeline`} class="timeline-link-btn">📅 タイムライン</a>
                <button id="toggleDarkMode" class="dark-mode-btn" title="ダークモード切替">🌙</button>
            </div>
        </div>
    </header>

    <SearchBox />

    <!-- プリセットエリア -->
    <div class="preset-area" id="presetArea">
        <div class="preset-save-row">
            <button type="button" id="savePresetBtn" class="save-preset-btn">★ 現在の条件を保存</button>
        </div>
        <div id="presetButtons" class="preset-buttons"></div>
    </div>

    <!-- 統計ダッシュボード -->
    <div class="dashboard" id="dashboard" style="display: none;">
        <div class="dashboard-grid">
            <div class="dashboard-card">
                <div class="dashboard-number" id="totalCount">0</div>
                <div class="dashboard-label">総配布数</div>
            </div>
            <div class="dashboard-card">
                <div class="dashboard-number" id="shinyCount">0</div>
                <div class="dashboard-label">色違い</div>
            </div>
            <div class="dashboard-card">
                <div class="dashboard-number" id="activeCount">0</div>
                <div class="dashboard-label">配信中</div>
            </div>
            <div class="dashboard-card">
                <div class="dashboard-number" id="favoriteCount">0</div>
                <div class="dashboard-label">お気に入り</div>
            </div>
            <div class="dashboard-card">
                <div class="dashboard-number" id="ownedCount">0</div>
                <div class="dashboard-label">所持済み</div>
            </div>
        </div>
        <button id="toggleDashboard" class="toggle-dashboard-btn">📊 統計を閉じる</button>
    </div>
    <button id="showDashboard" class="show-dashboard-btn" style="display: none;">📊 統計を表示</button>

    <!-- コレクション統計 -->
    <div class="collection-stats-panel" id="collectionStatsPanel" style="display:none;">
        <div class="collection-stats-inner" id="collectionStatsInner">
            <!-- updateCollectionStats() で動的生成 -->
        </div>
    </div>
    <button id="toggleCollectionStats" class="toggle-collection-stats-btn">📊 コレクション統計を表示</button>

    <div class="stats" id="stats" style="display: none;">
        <div class="stats-left">
            <span id="resultCount"></span>
            <div class="stats-actions">
                <button id="showFavorites" class="action-btn" title="お気に入りのみ表示">⭐ お気に入り</button>
                <button id="showOwned" class="action-btn" title="所持済みのみ表示">📦 所持済み</button>
                <button id="toggleCompareMode" class="action-btn" title="比較モード">🔄 比較</button>
                <button id="compareSelected" class="compare-btn" style="display: none;">選択した配信を比較 (<span id="compareCount">0</span>個)</button>
            </div>
        </div>
        <div class="quick-filters" id="quickFilters">
            <button class="quick-filter-btn" data-filter="shiny">
                <span class="quick-icon">✨</span>
                <span class="quick-text">色違い</span>
            </button>
            <button class="quick-filter-btn" data-filter="gigantamax">
                <span class="quick-icon">🔷</span>
                <span class="quick-text">キョダイ</span>
            </button>
            <button class="quick-filter-btn" data-filter="alpha">
                <span class="quick-icon">👑</span>
                <span class="quick-text">オヤブン</span>
            </button>
            <button class="quick-filter-btn" data-filter="moves">
                <span class="quick-icon">🎯</span>
                <span class="quick-text">技</span>
            </button>
            <button class="quick-filter-btn" data-filter="item">
                <span class="quick-icon">🎁</span>
                <span class="quick-text">持ち物</span>
            </button>
        </div>
    </div>

    <div class="loading" id="loading">読み込み中...</div>

    <div class="results" id="results"></div>

    <!-- 無限スクロール用ローディング -->
    <div class="infinite-scroll-loader" id="infiniteScrollLoader" style="display: none;">
        <div class="loader-spinner"></div>
        <span>読み込み中...</span>
    </div>
    <div id="scrollSentinel" style="height: 1px;"></div>

    <!-- 一番上に戻るボタン -->
    <button id="scrollToTop" class="scroll-to-top" aria-label="一番上に戻る">↑</button>

    <PokemonCard />
</Layout>

<script define:vars={{ baseUrl }}>
    let allData = [];
    let displayedCount = 0;
    const ITEMS_PER_PAGE = 24;
    const JSON_URL = `${baseUrl.endsWith('/') ? baseUrl : baseUrl + '/'}pokemon.json`;

    // 無限スクロール用の状態管理
    let currentDisplayData = [];
    let isLoadingMore = false;
    let infiniteScrollObserver = null;

    // リボン複数選択
    let selectedRibbons = [];
    let ribbonFilterMode = 'OR';

    // セキュリティ: HTMLエスケープ関数
    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    // リボン複数選択管理
    function addRibbon(value) {
        const v = value.trim();
        if (!v || selectedRibbons.includes(v)) return;
        selectedRibbons.push(v);
        const input = document.getElementById('filterRibbonInput');
        if (input) input.value = '';
        renderRibbonTags();
        searchPokemon();
    }

    function removeRibbon(value) {
        selectedRibbons = selectedRibbons.filter(r => r !== value);
        renderRibbonTags();
        searchPokemon();
    }

    function renderRibbonTags() {
        const container = document.getElementById('selectedRibbonTags');
        const modeRow = document.getElementById('ribbonModeRow');
        if (!container) return;
        container.innerHTML = '';
        selectedRibbons.forEach(ribbon => {
            const tag = document.createElement('span');
            tag.className = 'ribbon-tag';
            tag.innerHTML = `${escapeHtml(ribbon)} <button type="button" data-ribbon="${escapeHtml(ribbon)}">×</button>`;
            tag.querySelector('button').addEventListener('click', () => removeRibbon(ribbon));
            container.appendChild(tag);
        });
        if (modeRow) {
            modeRow.style.display = selectedRibbons.length >= 2 ? 'flex' : 'none';
            // 現在のモードをUIに反映
            const modeRadios = document.querySelectorAll('input[name="ribbonMode"]');
            modeRadios.forEach(radio => {
                radio.checked = radio.value === ribbonFilterMode;
            });
        }
    }

    // お気に入り管理
    function getFavorites() {
        try {
            const stored = localStorage.getItem('pokemon-favorites');
            return stored ? JSON.parse(stored) : [];
        } catch (e) {
            console.error('Failed to parse favorites:', e);
            return [];
        }
    }

    function saveFavorites(favorites) {
        localStorage.setItem('pokemon-favorites', JSON.stringify(favorites));
        updateFavoriteCount();
    }

    function toggleFavorite(managementId) {
        const favorites = getFavorites();
        const index = favorites.indexOf(managementId);
        if (index === -1) {
            favorites.push(managementId);
        } else {
            favorites.splice(index, 1);
        }
        saveFavorites(favorites);
        return index === -1; // true if added
    }

    function isFavorite(managementId) {
        return getFavorites().includes(managementId);
    }

    function updateFavoriteCount() {
        const count = getFavorites().length;
        document.getElementById('favoriteCount').textContent = count;
    }

    // 所持管理
    function getOwned() {
        try {
            const stored = localStorage.getItem('pokemon-owned');
            return stored ? JSON.parse(stored) : [];
        } catch (e) { return []; }
    }
    function saveOwned(owned) {
        localStorage.setItem('pokemon-owned', JSON.stringify(owned));
        updateOwnedCount();
    }
    function toggleOwned(managementId) {
        const owned = getOwned();
        const index = owned.indexOf(managementId);
        if (index === -1) { owned.push(managementId); }
        else { owned.splice(index, 1); }
        saveOwned(owned);
        return index === -1;
    }
    function isOwned(managementId) {
        return getOwned().includes(managementId);
    }
    function updateOwnedCount() {
        const el = document.getElementById('ownedCount');
        if (el) el.textContent = getOwned().length;
    }

    // メモ管理（保管場所・カスタムメモ）
    function getNotes() {
        try {
            const stored = localStorage.getItem('pokemon-notes');
            return stored ? JSON.parse(stored) : {};
        } catch (e) {
            console.error('Failed to parse notes:', e);
            return {};
        }
    }

    function saveNote(managementId, noteData) {
        const notes = getNotes();
        notes[managementId] = noteData;
        localStorage.setItem('pokemon-notes', JSON.stringify(notes));
    }

    function getNote(managementId) {
        const notes = getNotes();
        return notes[managementId] || { location: '', customNote: '' };
    }

    function deleteNote(managementId) {
        const notes = getNotes();
        delete notes[managementId];
        localStorage.setItem('pokemon-notes', JSON.stringify(notes));
    }

    // 保管場所プリセット
    const LOCATION_PRESETS = [
        { value: 'home', label: '📱 HOME保管中', icon: '📱' },
        { value: 'violet', label: '🟣 バイオレット', icon: '🟣' },
        { value: 'scarlet', label: '🔴 スカーレット', icon: '🔴' },
        { value: 'sword', label: '⚔️ ソード', icon: '⚔️' },
        { value: 'shield', label: '🛡️ シールド', icon: '🛡️' },
        { value: 'bdsp', label: '💎 ダイパリメイク', icon: '💎' },
        { value: 'legends', label: '🏔️ アルセウス', icon: '🏔️' },
        { value: 'custom', label: '✏️ カスタム', icon: '✏️' }
    ];

    function getLocationIcon(locationValue) {
        const preset = LOCATION_PRESETS.find(p => p.value === locationValue);
        return preset ? preset.icon : '📝';
    }

    // ダークモード
    function initDarkMode() {
        const isDark = localStorage.getItem('dark-mode') === 'true';
        if (isDark) {
            document.body.classList.add('dark-mode');
            document.getElementById('toggleDarkMode').textContent = '☀️';
        }
    }

    function toggleDarkMode() {
        const isDark = document.body.classList.toggle('dark-mode');
        localStorage.setItem('dark-mode', isDark);
        document.getElementById('toggleDarkMode').textContent = isDark ? '☀️' : '🌙';
    }

    // 画像URL生成関数
    const isLocal = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
    const assetBase = isLocal
        ? '/distribution/images'
        : 'https://www.pokebros.net/wp-content/uploads/pokemon-assets';
    const imageBaseUrl = `${assetBase}/pokemon/pokedex`;
    const ballImageBaseUrl = `${assetBase}/balls`;
    const ribbonImageBaseUrl = `${assetBase}/ribbons`;
    const markImageBaseUrl = `${assetBase}/marks`;

    function getPokemonImageUrl(pokemon) {
        const dexNo = String(pokemon.dexNo).padStart(4, '0');
        const name = pokemon.gigantamax
            ? `キョダイマックス${pokemon.pokemonName}`
            : pokemon.pokemonName;
        return `${imageBaseUrl}/${dexNo}_${name}.png`;
    }

    function isMarkName(name) {
        return name.endsWith('あかし');
    }

    function getRibbonImageUrl(name) {
        return isMarkName(name)
            ? `${markImageBaseUrl}/${name}.png`
            : `${ribbonImageBaseUrl}/${name}.png`;
    }

    function getBallImageUrl(name) {
        return `${ballImageBaseUrl}/${name}.png`;
    }

    // URLパラメータからフィルター初期状態を設定
    function applyUrlParameters() {
        const params = new URLSearchParams(window.location.search);

        const filters = [
            { param: 'shiny', id: 'filterShiny' },
            { param: 'gigantamax', id: 'filterGigantamax' },
            { param: 'alpha', id: 'filterAlpha' },
            { param: 'moves', id: 'filterSpecialMoves' },
            { param: 'item', id: 'filterHeldItem' },
            { param: 'active', id: 'filterActive' }
        ];

        let hasFilters = false;

        filters.forEach(({ param, id }) => {
            if (params.get(param) === '1') {
                hasFilters = true;
                const el = document.getElementById(id);
                if (el) el.checked = true;
            }
        });

        // 地域パラメータ
        const region = params.get('region');
        if (region) {
            hasFilters = true;
            const regionSelect = document.getElementById('filterRegion');
            if (regionSelect) regionSelect.value = region;
        }

        // ゲーム複数対応（?game=SV&game=LA など）
        const gameParams = params.getAll('game');
        if (gameParams.length > 0) {
            document.querySelectorAll('.game-tag-btn').forEach(btn => {
                if (gameParams.includes(btn.dataset.game)) btn.classList.add('active');
            });
            hasFilters = true;
        }

        // リボン複数対応（?ribbon=クラシック&ribbon=バースデー など）
        const ribbonParams = params.getAll('ribbon');
        if (ribbonParams.length > 0) {
            selectedRibbons = ribbonParams;
            renderRibbonTags();
            hasFilters = true;
        }

        if (hasFilters) {
            searchPokemon();
        }
    }

    // プリセット管理
    function getPresets() {
        try { return JSON.parse(localStorage.getItem('pokemon-search-presets') || '[]'); }
        catch { return []; }
    }

    function getCurrentFilterState() {
        return {
            searchName: document.getElementById('searchName')?.value || '',
            generation: document.getElementById('filterGeneration')?.value || '',
            games: [...document.querySelectorAll('.game-tag-btn.active')].map(b => b.dataset.game),
            method: document.getElementById('filterMethod')?.value || '',
            region: document.getElementById('filterRegion')?.value || '',
            shiny: document.getElementById('filterShiny')?.checked || false,
            gigantamax: document.getElementById('filterGigantamax')?.checked || false,
            alpha: document.getElementById('filterAlpha')?.checked || false,
            specialMoves: document.getElementById('filterSpecialMoves')?.checked || false,
            heldItem: document.getElementById('filterHeldItem')?.checked || false,
            active: document.getElementById('filterActive')?.checked || false,
            ribbons: [...selectedRibbons],
            ribbonMode: ribbonFilterMode,
            dateFrom: document.getElementById('filterDateFrom')?.value || '',
            dateTo: document.getElementById('filterDateTo')?.value || '',
            ot: document.getElementById('filterOT')?.value || '',
            trainerId: document.getElementById('filterTrainerId')?.value || '',
            sortOrder: document.getElementById('sortOrder')?.value || 'date-desc'
        };
    }

    function applyFilterState(filters) {
        if (document.getElementById('searchName')) document.getElementById('searchName').value = filters.searchName || '';
        if (document.getElementById('filterGeneration')) document.getElementById('filterGeneration').value = filters.generation || '';
        if (document.getElementById('filterMethod')) document.getElementById('filterMethod').value = filters.method || '';
        if (document.getElementById('filterRegion')) document.getElementById('filterRegion').value = filters.region || '';
        if (document.getElementById('filterShiny')) document.getElementById('filterShiny').checked = filters.shiny || false;
        if (document.getElementById('filterGigantamax')) document.getElementById('filterGigantamax').checked = filters.gigantamax || false;
        if (document.getElementById('filterAlpha')) document.getElementById('filterAlpha').checked = filters.alpha || false;
        if (document.getElementById('filterSpecialMoves')) document.getElementById('filterSpecialMoves').checked = filters.specialMoves || false;
        if (document.getElementById('filterHeldItem')) document.getElementById('filterHeldItem').checked = filters.heldItem || false;
        if (document.getElementById('filterActive')) document.getElementById('filterActive').checked = filters.active || false;
        if (document.getElementById('filterDateFrom')) document.getElementById('filterDateFrom').value = filters.dateFrom || '';
        if (document.getElementById('filterDateTo')) document.getElementById('filterDateTo').value = filters.dateTo || '';
        if (document.getElementById('filterOT')) document.getElementById('filterOT').value = filters.ot || '';
        if (document.getElementById('filterTrainerId')) document.getElementById('filterTrainerId').value = filters.trainerId || '';
        if (document.getElementById('sortOrder')) document.getElementById('sortOrder').value = filters.sortOrder || 'date-desc';

        // ゲームタグ
        document.querySelectorAll('.game-tag-btn').forEach(btn => {
            btn.classList.toggle('active', (filters.games || []).includes(btn.dataset.game));
        });

        // リボン
        selectedRibbons = filters.ribbons || [];
        ribbonFilterMode = filters.ribbonMode || 'OR';
        renderRibbonTags();

        searchPokemon();
    }

    function savePreset(name) {
        const presets = getPresets();
        if (presets.length >= 5) {
            alert('プリセットは最大5件まで保存できます。');
            return;
        }
        presets.push({ id: `preset_${Date.now()}`, name, filters: getCurrentFilterState() });
        localStorage.setItem('pokemon-search-presets', JSON.stringify(presets));
        renderPresets();
    }

    function deletePreset(id) {
        const presets = getPresets().filter(p => p.id !== id);
        localStorage.setItem('pokemon-search-presets', JSON.stringify(presets));
        renderPresets();
    }

    function renderPresets() {
        const container = document.getElementById('presetButtons');
        if (!container) return;
        const presets = getPresets();
        container.innerHTML = '';
        presets.forEach(preset => {
            const wrap = document.createElement('span');
            wrap.className = 'preset-btn-wrap';
            wrap.innerHTML = `
                <button type="button" class="preset-btn" data-id="${escapeHtml(preset.id)}">${escapeHtml(preset.name)}</button>
                <button type="button" class="preset-delete-btn" data-id="${escapeHtml(preset.id)}" title="削除">×</button>
            `;
            wrap.querySelector('.preset-btn').addEventListener('click', () => applyFilterState(preset.filters));
            wrap.querySelector('.preset-delete-btn').addEventListener('click', () => {
                if (confirm(`「${preset.name}」を削除しますか？`)) deletePreset(preset.id);
            });
            container.appendChild(wrap);
        });
    }

    // Load data on page load
    async function loadData() {
        try {
            const response = await fetch(JSON_URL);
            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }
            const data = await response.json();

            // データ検証
            if (!Array.isArray(data)) {
                throw new Error('Invalid data format: expected array');
            }

            allData = data;

            document.getElementById('loading').style.display = 'none';
            document.getElementById('stats').style.display = 'flex';
            document.getElementById('dashboard').style.display = 'block';

            populateFilters();
            updateDashboard();
            applyUrlParameters();

            const params = new URLSearchParams(window.location.search);
            if (![...params.keys()].some(key => ['shiny', 'gigantamax', 'alpha', 'moves', 'ribbon', 'game', 'item', 'region', 'active'].includes(key))) {
                const sortOrder = document.getElementById('sortOrder')?.value || 'date-desc';
                searchResults = sortData(allData, sortOrder);
                displayResults(searchResults);
            }
        } catch (error) {
            console.error('Data loading error:', error);
            document.getElementById('loading').innerHTML =
                '<div style="background: white; padding: 30px; border-radius: 8px; color: #d32f2f;">データの読み込みに失敗しました。<br>URLを確認してください。</div>';
        }
    }

    // ダッシュボード更新
    function updateDashboard() {
        document.getElementById('totalCount').textContent = allData.length;
        document.getElementById('shinyCount').textContent = allData.filter(p => p.shiny && p.shiny !== '').length;
        document.getElementById('activeCount').textContent = allData.filter(p => isDistributionActive(p.endDate)).length;
        updateFavoriteCount();
        updateOwnedCount();
    }

    // Populate filter dropdowns from data
    function populateFilters() {
        const games = [...new Set(allData.map(p => p.game))].sort();
        const methods = [...new Set(allData.map(p => p.distributionMethod))].sort();

        const gameContainer = document.getElementById('gameFilterButtons');
        games.forEach(game => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'game-tag-btn';
            btn.dataset.game = game;
            btn.textContent = getGameShortName(game);
            btn.addEventListener('click', () => {
                btn.classList.toggle('active');
                searchPokemon();
            });
            gameContainer.appendChild(btn);
        });

        const methodSelect = document.getElementById('filterMethod');
        methods.forEach(method => {
            const option = document.createElement('option');
            option.value = method;
            option.textContent = method;
            methodSelect.appendChild(option);
        });

        // リボンのリストを抽出
        const ribbonSet = new Set();
        allData.forEach(p => {
            const ribbons = p.ribbons && Array.isArray(p.ribbons)
                ? p.ribbons.filter(r => r && r !== '')
                : [p.ribbon1, p.ribbon2, p.ribbon3].filter(r => r && r !== '');
            ribbons.forEach(r => ribbonSet.add(r));
        });
        const ribbons = [...ribbonSet].sort();

        const ribbonList = document.getElementById('ribbonList');
        ribbons.forEach(ribbon => {
            const option = document.createElement('option');
            option.value = ribbon;
            ribbonList.appendChild(option);
        });
    }

    // 検索結果を保存
    let searchResults = [];
    let showingFavorites = false;

    // 比較機能
    let compareMode = false;
    let selectedForCompare = [];

    // ソート関数（同値の場合はmanagementIdで安定ソート）
    function sortData(data, sortOrder) {
        const sorted = [...data];
        sorted.sort((a, b) => {
            let result = 0;
            switch (sortOrder) {
                case 'date-desc':
                    result = (b.startDate || '').localeCompare(a.startDate || '');
                    break;
                case 'date-asc':
                    result = (a.startDate || '').localeCompare(b.startDate || '');
                    break;
                case 'dex-asc':
                    result = (a.dexNo || 0) - (b.dexNo || 0);
                    break;
                case 'dex-desc':
                    result = (b.dexNo || 0) - (a.dexNo || 0);
                    break;
                case 'name-asc':
                    result = (a.pokemonName || '').localeCompare(b.pokemonName || '', 'ja');
                    break;
                case 'name-desc':
                    result = (b.pokemonName || '').localeCompare(a.pokemonName || '', 'ja');
                    break;
            }
            // 同値の場合はmanagementIdで安定化
            if (result === 0) {
                result = (a.managementId || '').localeCompare(b.managementId || '');
            }
            return result;
        });
        return sorted;
    }

    // Search function
    function searchPokemon() {
        const searchName = document.getElementById('searchName').value.toLowerCase();
        const filterGeneration = document.getElementById('filterGeneration').value;
        const selectedGames = [...document.querySelectorAll('.game-tag-btn.active')].map(b => b.dataset.game);
        const filterMethod = document.getElementById('filterMethod').value;
        const filterRegion = document.getElementById('filterRegion').value;
        const filterShiny = document.getElementById('filterShiny')?.checked;
        const filterGigantamax = document.getElementById('filterGigantamax')?.checked;
        const filterAlpha = document.getElementById('filterAlpha')?.checked;
        const filterSpecialMoves = document.getElementById('filterSpecialMoves')?.checked;
        const filterHeldItem = document.getElementById('filterHeldItem')?.checked;
        const filterActive = document.getElementById('filterActive')?.checked;
        const filterDateFrom = document.getElementById('filterDateFrom')?.value;
        const filterDateTo = document.getElementById('filterDateTo')?.value;
        const filterOT = document.getElementById('filterOT')?.value.toLowerCase();
        const filterTrainerId = document.getElementById('filterTrainerId')?.value;
        const sortOrder = document.getElementById('sortOrder')?.value || 'date-desc';

        let filtered = allData;

        // Filter by Pokemon name, event name, OT, distribution info, notes
        if (searchName) {
            filtered = filtered.filter(p => {
                const otStr = typeof p.ot === 'object'
                    ? Object.values(p.ot).join(' ').toLowerCase()
                    : (p.ot || '').toLowerCase();
                return p.pokemonName.toLowerCase().includes(searchName) ||
                    p.eventName.toLowerCase().includes(searchName) ||
                    otStr.includes(searchName) ||
                    (p.distributionMethod || '').toLowerCase().includes(searchName) ||
                    (p.distributionLocation || '').toLowerCase().includes(searchName) ||
                    (p.notes || '').toLowerCase().includes(searchName);
            });
        }

        // Filter by generation
        if (filterGeneration) {
            filtered = filtered.filter(p => p.generation === parseInt(filterGeneration));
        }

        // Filter by game (複数選択)
        if (selectedGames.length > 0) {
            filtered = filtered.filter(p => selectedGames.includes(p.game));
        }

        // Filter by distribution method
        if (filterMethod) {
            filtered = filtered.filter(p => p.distributionMethod === filterMethod);
        }

        // Filter by region
        if (filterRegion) {
            filtered = filtered.filter(p => p.region === filterRegion);
        }

        // Filter by date range
        if (filterDateFrom) {
            filtered = filtered.filter(p => p.startDate && p.startDate >= filterDateFrom);
        }
        if (filterDateTo) {
            filtered = filtered.filter(p => p.startDate && p.startDate <= filterDateTo);
        }

        // Filter by shiny
        if (filterShiny) {
            filtered = filtered.filter(p => p.shiny && p.shiny !== '');
        }

        // Filter by Gigantamax
        if (filterGigantamax) {
            filtered = filtered.filter(p => p.gigantamax && p.gigantamax !== '');
        }

        // Filter by Alpha
        if (filterAlpha) {
            filtered = filtered.filter(p => p.isAlpha && p.isAlpha !== '');
        }

        // Filter by special moves flag
        if (filterSpecialMoves) {
            filtered = filtered.filter(p => p.specialMoves && p.specialMoves !== '');
        }

        // Filter by ribbons (複数選択・AND/OR)
        if (selectedRibbons.length > 0) {
            filtered = filtered.filter(p => {
                const ribbons = p.ribbons && Array.isArray(p.ribbons)
                    ? p.ribbons.filter(r => r && r !== '')
                    : [p.ribbon1, p.ribbon2, p.ribbon3].filter(r => r && r !== '');
                if (ribbonFilterMode === 'AND') {
                    return selectedRibbons.every(sel => ribbons.some(r => r.toLowerCase().includes(sel.toLowerCase())));
                } else {
                    return selectedRibbons.some(sel => ribbons.some(r => r.toLowerCase().includes(sel.toLowerCase())));
                }
            });
        }

        // Filter by held item
        if (filterHeldItem) {
            filtered = filtered.filter(p => p.heldItem && p.heldItem !== '');
        }

        // Filter by active distribution
        if (filterActive) {
            filtered = filtered.filter(p => isDistributionActive(p.endDate));
        }

        // Filter by OT (親名) - supports multi-language OT
        if (filterOT) {
            filtered = filtered.filter(p => {
                if (!p.ot) return false;
                if (typeof p.ot === 'string') {
                    return p.ot.toLowerCase().includes(filterOT);
                }
                // Multi-language OT object
                if (typeof p.ot === 'object') {
                    return Object.values(p.ot).some(otValue =>
                        otValue && otValue.toLowerCase().includes(filterOT)
                    );
                }
                return false;
            });
        }

        // Filter by Trainer ID
        if (filterTrainerId) {
            filtered = filtered.filter(p => {
                if (!p.trainerId) return false;
                return String(p.trainerId).includes(filterTrainerId);
            });
        }

        // Apply sort
        filtered = sortData(filtered, sortOrder);

        // Reset display count
        displayedCount = 0;
        showingFavorites = false;
        showingOwned = false;
        document.getElementById('showFavorites').classList.remove('active');
        document.getElementById('showOwned').classList.remove('active');

        searchResults = filtered;
        resetQuickFilters();
        displayResults(filtered);
    }

    // 素早い絞り込み機能
    function applyQuickFilter() {
        let filtered = searchResults;

        const activeFilters = [...document.querySelectorAll('.quick-filter-btn.active')]
            .map(btn => btn.dataset.filter);

        activeFilters.forEach(filter => {
            switch(filter) {
                case 'shiny':
                    filtered = filtered.filter(p => p.shiny && p.shiny !== '');
                    break;
                case 'gigantamax':
                    filtered = filtered.filter(p => p.gigantamax && p.gigantamax !== '');
                    break;
                case 'alpha':
                    filtered = filtered.filter(p => p.isAlpha && p.isAlpha !== '');
                    break;
                case 'moves':
                    filtered = filtered.filter(p => {
                        const moves = p.moves && Array.isArray(p.moves)
                            ? p.moves.filter(m => m && m !== '')
                            : [p.move1, p.move2, p.move3, p.move4].filter(m => m && m !== '');
                        return moves.length > 0;
                    });
                    break;
                case 'item':
                    filtered = filtered.filter(p => p.heldItem && p.heldItem !== '');
                    break;
            }
        });

        displayedCount = 0;
        displayResults(filtered);
    }

    // 素早い絞り込みをリセット
    function resetQuickFilters() {
        document.querySelectorAll('.quick-filter-btn').forEach(btn => {
            btn.classList.remove('active');
        });
    }

    // モバイルで結果エリアにスクロール
    function scrollToResults() {
        if (window.innerWidth <= 768) {
            const resultsEl = document.getElementById('results');
            setTimeout(() => {
                resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 100);
        }
    }

    // Format date for display
    function formatDate(dateStr) {
        if (!dateStr) return '';
        const date = new Date(dateStr);
        return `${date.getFullYear()}/${(date.getMonth() + 1).toString().padStart(2, '0')}/${date.getDate().toString().padStart(2, '0')}`;
    }

    // Check if distribution is active
    function isDistributionActive(endDate) {
        if (!endDate) return true;
        const now = new Date();
        const end = new Date(endDate);
        return now <= end;
    }

    // Create distribution status badge
    function createStatusBadge(endDate) {
        const isActive = isDistributionActive(endDate);
        const statusClass = isActive ? 'status-active' : 'status-ended';
        const statusText = isActive ? '配信中' : '終了';
        return `<span class="status-badge ${statusClass}">${statusText}</span>`;
    }

    // Game short name mapping
    const gameShortNames = {
        "ソード, シールド": "剣盾",
        "ブリリアントダイヤモンド, シャイニングパール": "BDSP",
        "Pokémon LEGENDS アルセウス": "LA",
        "スカーレット, バイオレット": "SV",
        "Pokémon LEGENDS Z-A": "ZA"
    };
    function getGameShortName(game) {
        return gameShortNames[game] || game;
    }

    // Game type detection helpers
    function isSwSh(game) {
        return game && (game.includes('ソード') || game.includes('シールド'));
    }

    function isSV(game) {
        return game && (game.includes('スカーレット') || game.includes('バイオレット'));
    }

    function isLegendsGame(game) {
        return game && (game.includes('アルセウス') || game.includes('Z-A'));
    }

    // Create a Pokemon card element
    function createPokemonCard(pokemon) {
        const template = document.getElementById('pokemon-card-template');
        const card = template.content.cloneNode(true);
        const cardEl = card.querySelector('.pokemon-card');

        cardEl.dataset.pokemonData = JSON.stringify(pokemon);
        cardEl.dataset.managementId = pokemon.managementId;

        // ポケモン画像の設定
        const imgEl = cardEl.querySelector('.pokemon-image');
        imgEl.src = getPokemonImageUrl(pokemon);
        imgEl.alt = pokemon.pokemonName;
        imgEl.addEventListener('error', function() {
            this.style.display = 'none';
        });

        // Name
        cardEl.querySelector('.pokemon-name').textContent = pokemon.pokemonName;

        // Dex Number
        cardEl.querySelector('.dex-number').textContent = `No.${String(pokemon.dexNo).padStart(3, '0')}`;

        let badgesHtml = '';
        if (pokemon.shiny && pokemon.shiny !== '') {
            badgesHtml += '<span class="icon-badge" title="色違い">✨</span>';
        }
        if (pokemon.gigantamax && pokemon.gigantamax !== '' && isSwSh(pokemon.game)) {
            badgesHtml += '<span class="icon-badge" title="キョダイマックス">🔷</span>';
        }
        if (pokemon.teraType && pokemon.teraType !== '' && isSV(pokemon.game)) {
            badgesHtml += `<span class="tera-type-badge" title="テラスタイプ: ${pokemon.teraType}">${pokemon.teraType}</span>`;
        }
        if (pokemon.isAlpha && pokemon.isAlpha !== '' && isLegendsGame(pokemon.game)) {
            badgesHtml += '<span class="icon-badge" title="オヤブン">👑</span>';
        }
        cardEl.querySelector('.badges').innerHTML = badgesHtml;

        // Generation badge
        const genBadge = cardEl.querySelector('.generation-badge');
        genBadge.textContent = `第${pokemon.generation}世代`;
        genBadge.classList.add(`gen-${pokemon.generation}`);

        // Basic info
        cardEl.querySelector('.event-name').textContent = pokemon.eventName;

        const startDate = formatDate(pokemon.startDate);
        const endDate = pokemon.endDate ? formatDate(pokemon.endDate) : '終了日未定';
        cardEl.querySelector('.distribution-period').textContent = `${startDate} 〜 ${endDate}`;

        cardEl.querySelector('.distribution-status').innerHTML = createStatusBadge(pokemon.endDate);
        cardEl.querySelector('.distribution-method').textContent = pokemon.distributionMethod;
        cardEl.querySelector('.distribution-location').textContent = pokemon.distributionLocation;

        // Region badge
        if (pokemon.region) {
            const regionRow = cardEl.querySelector('.region-row');
            if (regionRow) {
                regionRow.style.display = 'flex';
                cardEl.querySelector('.region-value').textContent = pokemon.region;
            }
        }

        // Ribbons
        const ribbons = pokemon.ribbons && Array.isArray(pokemon.ribbons)
            ? pokemon.ribbons.filter(r => r && r !== '')
            : [pokemon.ribbon1, pokemon.ribbon2, pokemon.ribbon3].filter(r => r && r !== '');
        if (ribbons.length > 0) {
            const ribbonsRow = cardEl.querySelector('.ribbons-row');
            ribbonsRow.style.display = 'flex';
            cardEl.querySelector('.ribbons').innerHTML = ribbons.map(ribbon =>
                `<span class="ribbon-icon"><img src="${getRibbonImageUrl(ribbon)}" alt="" onerror="this.style.display='none';this.nextElementSibling.style.display='inline'"><span style="display:none">${isMarkName(ribbon) ? '🏅' : '🎀'}</span> ${ribbon}</span>`
            ).join('');
        }

        // Favorite button
        const favBtn = cardEl.querySelector('.favorite-btn');
        if (favBtn) {
            favBtn.classList.toggle('active', isFavorite(pokemon.managementId));
            favBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                const added = toggleFavorite(pokemon.managementId);
                favBtn.classList.toggle('active', added);
            });
        }

        // Owned button
        const ownedBtn = cardEl.querySelector('.owned-btn');
        if (ownedBtn) {
            ownedBtn.classList.toggle('active', isOwned(pokemon.managementId));
            ownedBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                const added = toggleOwned(pokemon.managementId);
                ownedBtn.classList.toggle('active', added);
                cardEl.classList.toggle('is-owned', added);
                updateCollectionStats();
            });
        }
        // カード初期状態
        cardEl.classList.toggle('is-owned', isOwned(pokemon.managementId));

        // Location badge (保管場所バッジ)
        const locationBadge = cardEl.querySelector('.location-badge');
        const noteData = getNote(pokemon.managementId);
        if (noteData.location) {
            const icon = getLocationIcon(noteData.location);
            locationBadge.textContent = icon;
            locationBadge.style.display = 'flex';
            locationBadge.title = noteData.customNote || '保管場所設定済み';
        }

        // Compare checkbox (比較用チェックボックス)
        const compareCheckbox = cardEl.querySelector('.compare-checkbox');
        if (compareCheckbox) {
            compareCheckbox.style.display = compareMode ? 'flex' : 'none';
            compareCheckbox.checked = selectedForCompare.includes(pokemon.managementId);

            compareCheckbox.addEventListener('change', (e) => {
                e.stopPropagation();
                if (e.target.checked) {
                    if (selectedForCompare.length >= 5) {
                        e.target.checked = false;
                        alert('比較できるのは最大5個までです');
                        return;
                    }
                    selectedForCompare.push(pokemon.managementId);
                } else {
                    selectedForCompare = selectedForCompare.filter(id => id !== pokemon.managementId);
                }
                updateCompareButton();
            });
        }

        return card;
    }

