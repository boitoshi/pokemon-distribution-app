        const memoCustomNote = modalEl.querySelector('#memoCustomNote');
        const memoSaveBtn = modalEl.querySelector('#memoSaveBtn');
        const memoDeleteBtn = modalEl.querySelector('#memoDeleteBtn');

        // Load existing memo
        const existingNote = getNote(pokemon.managementId);
        if (memoLocationSelect) memoLocationSelect.value = existingNote.location || '';
        if (memoCustomNote) memoCustomNote.value = existingNote.customNote || '';

        // Save memo
        if (memoSaveBtn) {
            memoSaveBtn.addEventListener('click', () => {
                const noteData = {
                    location: memoLocationSelect.value,
                    customNote: memoCustomNote.value
                };
                saveNote(pokemon.managementId, noteData);

                // Update card location badge
                const card = document.querySelector(`[data-management-id="${pokemon.managementId}"]`);
                if (card) {
                    const locationBadge = card.querySelector('.location-badge');
                    if (noteData.location) {
                        const icon = getLocationIcon(noteData.location);
                        locationBadge.textContent = icon;
                        locationBadge.style.display = 'flex';
                        locationBadge.title = noteData.customNote || '保管場所設定済み';
                    } else {
                        locationBadge.style.display = 'none';
                    }
                }

                // Visual feedback
                memoSaveBtn.textContent = '✅ 保存しました！';
                setTimeout(() => {
                    memoSaveBtn.textContent = '💾 保存';
                }, 2000);
            });
        }

        // Delete memo
        if (memoDeleteBtn) {
            memoDeleteBtn.addEventListener('click', () => {
                if (confirm('メモを削除しますか？')) {
                    deleteNote(pokemon.managementId);
                    if (memoLocationSelect) memoLocationSelect.value = '';
                    if (memoCustomNote) memoCustomNote.value = '';

                    // Update card location badge
                    const card = document.querySelector(`[data-management-id="${pokemon.managementId}"]`);
                    if (card) {
                        const locationBadge = card.querySelector('.location-badge');
                        locationBadge.style.display = 'none';
                    }

                    // Visual feedback
                    memoDeleteBtn.textContent = '🗑️ 削除しました';
                    setTimeout(() => {
                        memoDeleteBtn.textContent = '🗑️ メモ削除';
                    }, 2000);
                }
            });
        }

        document.body.appendChild(modal);

        const overlay = document.querySelector('.modal-overlay');
        const closeBtn = overlay.querySelector('.modal-close');
        const bottomCloseBtn = overlay.querySelector('.modal-bottom-close');

        const closeModal = () => {
            overlay.remove();
        };

        closeBtn.addEventListener('click', closeModal);
        bottomCloseBtn.addEventListener('click', closeModal);

        overlay.addEventListener('click', (e) => {
            if (e.target === overlay) {
                closeModal();
            }
        });

        // ESCキーで閉じる
        const escHandler = (e) => {
            if (e.key === 'Escape') {
                closeModal();
                document.removeEventListener('keydown', escHandler);
            }
        };
        document.addEventListener('keydown', escHandler);
    }

    // 無限スクロール: 追加読み込み
    function loadMoreItems() {
        if (isLoadingMore) return;
        if (displayedCount >= currentDisplayData.length) return;

        isLoadingMore = true;
        const loader = document.getElementById('infiniteScrollLoader');
        loader.style.display = 'flex';

        // 少し遅延を入れてローディング表示をスムーズに
        requestAnimationFrame(() => {
            const resultsDiv = document.getElementById('results');
            const endIndex = Math.min(displayedCount + ITEMS_PER_PAGE, currentDisplayData.length);
            const batchData = currentDisplayData.slice(displayedCount, endIndex);

            batchData.forEach(pokemon => {
                const cardFragment = createPokemonCard(pokemon);
                // カードにクリックイベントを付与
                const cardEl = cardFragment.querySelector('.pokemon-card');
                if (cardEl) {
                    cardEl.addEventListener('click', function(e) {
                        if (e.target.closest('.favorite-btn')) return;
                        if (e.target.closest('.owned-btn')) return;
                        if (e.target.closest('.compare-checkbox')) return;
                        const pokemonData = JSON.parse(this.dataset.pokemonData);
                        showDetailModal(pokemonData);
                    });
                }
                resultsDiv.appendChild(cardFragment);
            });

            displayedCount = endIndex;
            isLoadingMore = false;

            // 全件表示完了ならローダーを非表示
            if (displayedCount >= currentDisplayData.length) {
                loader.style.display = 'none';
            } else {
                loader.style.display = 'none';
            }
        });
    }

    // IntersectionObserver のセットアップ
    function setupInfiniteScroll() {
        // 既存のオブザーバーを破棄
        if (infiniteScrollObserver) {
            infiniteScrollObserver.disconnect();
        }

        const sentinel = document.getElementById('scrollSentinel');
        infiniteScrollObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting && displayedCount < currentDisplayData.length) {
                    loadMoreItems();
                }
            });
        }, {
            rootMargin: '200px'
        });

        infiniteScrollObserver.observe(sentinel);
    }

    // Display results with infinite scroll
    function displayResults(data) {
        const resultsDiv = document.getElementById('results');
        const resultCountDiv = document.getElementById('resultCount');
        const loader = document.getElementById('infiniteScrollLoader');

        currentDisplayData = data;
        displayedCount = 0;

        const totalItems = data.length;
        resultCountDiv.textContent = `${totalItems}件のポケモンが見つかりました`;

        if (totalItems === 0) {
            resultsDiv.innerHTML = '<div class="no-results">該当するポケモンが見つかりませんでした</div>';
            loader.style.display = 'none';
            return;
        }

        // 初回バッチを表示
        resultsDiv.innerHTML = '';
        const endIndex = Math.min(ITEMS_PER_PAGE, totalItems);
        const initialData = data.slice(0, endIndex);

        initialData.forEach(pokemon => {
            const cardFragment = createPokemonCard(pokemon);
            const cardEl = cardFragment.querySelector('.pokemon-card');
            if (cardEl) {
                cardEl.addEventListener('click', function(e) {
                    if (e.target.closest('.favorite-btn')) return;
                    if (e.target.closest('.owned-btn')) return;
                    if (e.target.closest('.compare-checkbox')) return;
                    const pokemonData = JSON.parse(this.dataset.pokemonData);
                    showDetailModal(pokemonData);
                });
            }
            resultsDiv.appendChild(cardFragment);
        });

        displayedCount = endIndex;

        // まだデータが残っている場合、無限スクロールを設定
        if (displayedCount < totalItems) {
            setupInfiniteScroll();
        } else {
            loader.style.display = 'none';
            if (infiniteScrollObserver) {
                infiniteScrollObserver.disconnect();
            }
        }

    }

    // Event listeners
    document.getElementById('searchButton').addEventListener('click', () => {
        searchPokemon();
        scrollToResults();
    });

    document.getElementById('searchName').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            searchPokemon();
            scrollToResults();
        }
    });

    // ソート変更時に再検索
    document.getElementById('sortOrder').addEventListener('change', () => {
        searchPokemon();
    });

    // 素早い絞り込みボタン
    document.querySelectorAll('.quick-filter-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            this.classList.toggle('active');
            applyQuickFilter();
        });
    });

    // お気に入り表示
    document.getElementById('showFavorites').addEventListener('click', function() {
        showingFavorites = !showingFavorites;
        this.classList.toggle('active', showingFavorites);
        showingOwned = false;
        document.getElementById('showOwned').classList.remove('active');

        if (showingFavorites) {
            const favorites = getFavorites();
            const favoriteData = allData.filter(p => favorites.includes(p.managementId));
            displayedCount = 0;
            displayResults(favoriteData);
        } else {
            displayResults(searchResults.length > 0 ? searchResults : allData);
        }
    });

    // 所持済み表示
    let showingOwned = false;
    document.getElementById('showOwned').addEventListener('click', function() {
        showingOwned = !showingOwned;
        this.classList.toggle('active', showingOwned);
        showingFavorites = false;
        document.getElementById('showFavorites').classList.remove('active');
        if (showingOwned) {
            const owned = getOwned();
            const ownedData = allData.filter(p => owned.includes(p.managementId));
            displayedCount = 0;
            displayResults(ownedData);
        } else {
            displayResults(searchResults.length > 0 ? searchResults : allData);
        }
    });

    // ダッシュボード表示切替
    document.getElementById('toggleDashboard').addEventListener('click', () => {
        document.getElementById('dashboard').style.display = 'none';
        document.getElementById('showDashboard').style.display = 'block';
    });

    document.getElementById('showDashboard').addEventListener('click', () => {
        document.getElementById('dashboard').style.display = 'block';
        document.getElementById('showDashboard').style.display = 'none';
    });

    // ダークモード切替
    document.getElementById('toggleDarkMode').addEventListener('click', toggleDarkMode);

    // 比較モード切替
    function updateCompareButton() {
        const compareBtn = document.getElementById('compareSelected');
        const countSpan = document.getElementById('compareCount');
        countSpan.textContent = selectedForCompare.length;

        if (selectedForCompare.length >= 2 && selectedForCompare.length <= 5) {
            compareBtn.style.display = 'block';
        } else {
            compareBtn.style.display = 'none';
        }
    }

    document.getElementById('toggleCompareMode').addEventListener('click', function() {
        compareMode = !compareMode;
        this.classList.toggle('active', compareMode);

        // Update all cards to show/hide checkboxes
        document.querySelectorAll('.compare-checkbox').forEach(checkbox => {
            checkbox.style.display = compareMode ? 'flex' : 'none';
        });

        if (!compareMode) {
            selectedForCompare = [];
            updateCompareButton();
        }
    });

    document.getElementById('compareSelected').addEventListener('click', () => {
        if (selectedForCompare.length >= 2 && selectedForCompare.length <= 5) {
            const pokemonToCompare = allData.filter(p => selectedForCompare.includes(p.managementId));
            showCompareModal(pokemonToCompare);
        }
    });

    // 比較モーダル表示
    function showCompareModal(pokemonList) {
        const modal = document.createElement('div');
        modal.className = 'modal-overlay';

        let modalHtml = `
            <div class="modal-content compare-modal-content">
                <button class="modal-close compare-modal-close">
                    <span class="pokeball-close"></span>
                </button>
                <div class="modal-body">
                    <h2 style="margin-bottom: 20px; text-align: center;">🔄 配信ポケモン比較</h2>
                    <div class="compare-grid">
        `;

        pokemonList.forEach(pokemon => {
            const moves = pokemon.moves && Array.isArray(pokemon.moves)
                ? pokemon.moves.filter(m => m && m !== '')
                : [pokemon.move1, pokemon.move2, pokemon.move3, pokemon.move4].filter(m => m && m !== '');

            const ribbons = pokemon.ribbons && Array.isArray(pokemon.ribbons)
                ? pokemon.ribbons.filter(r => r && r !== '')
                : [pokemon.ribbon1, pokemon.ribbon2, pokemon.ribbon3].filter(r => r && r !== '');

            const otLangLabels = { JPN: '日', ENG: '英', SPA: '西', SPA_EU: '欧西', SPA_LA: '米西', FRE: '仏', GER: '独', ITA: '伊', KOR: '韓', CHS: '簡中', CHT: '繁中' };
            const otDisplay = typeof pokemon.ot === 'object'
                ? Object.entries(pokemon.ot).map(([lang, name]) => `${escapeHtml(otLangLabels[lang] || lang)}: ${escapeHtml(name)}`).join(' / ')
                : escapeHtml(pokemon.ot) || '?';

            modalHtml += `
                <div class="compare-column">
                    <div class="compare-header">
                        <img src="${getPokemonImageUrl(pokemon)}" alt="${escapeHtml(pokemon.pokemonName)}" class="compare-image">
                        <h3>${escapeHtml(pokemon.pokemonName)} ${pokemon.shiny ? '✨' : ''}</h3>
                        <div class="compare-dex">No.${String(pokemon.dexNo).padStart(3, '0')}</div>
                    </div>
                    <div class="compare-details">
                        <div class="compare-row"><strong>世代:</strong> 第${pokemon.generation}世代</div>
                        <div class="compare-row"><strong>イベント:</strong> ${escapeHtml(pokemon.eventName)}</div>
                        <div class="compare-row"><strong>配信期間:</strong> ${formatDate(pokemon.startDate)} 〜 ${pokemon.endDate ? formatDate(pokemon.endDate) : '終了日未定'}</div>
                        <div class="compare-row"><strong>配信方法:</strong> ${escapeHtml(pokemon.distributionMethod)}</div>
                        ${pokemon.region ? `<div class="compare-row"><strong>地域:</strong> ${escapeHtml(pokemon.region)}</div>` : ''}
                        <div class="compare-row"><strong>ゲーム:</strong> ${escapeHtml(getGameShortName(pokemon.game))}</div>
                        <div class="compare-row"><strong>レベル:</strong> ${escapeHtml(String(pokemon.level)) || '?'}</div>
                        <div class="compare-row"><strong>親名:</strong> ${otDisplay}</div>
                        ${pokemon.trainerId ? `<div class="compare-row"><strong>ID:</strong> ${escapeHtml(String(pokemon.trainerId))}</div>` : ''}
                        ${pokemon.nature ? `<div class="compare-row"><strong>性格:</strong> ${escapeHtml(pokemon.nature)}</div>` : ''}
                        <div class="compare-row"><strong>特性:</strong> ${escapeHtml(pokemon.ability) || '?'}</div>
                        ${pokemon.ball ? `<div class="compare-row"><strong>ボール:</strong> <img src="${getBallImageUrl(pokemon.ball)}" alt="" class="ball-icon-img" onerror="this.style.display='none';this.nextElementSibling.style.display='inline'"><span style="display:none">⚪</span> ${escapeHtml(pokemon.ball)}</div>` : ''}
                        ${pokemon.teraType ? `<div class="compare-row"><strong>テラスタイプ:</strong> ${escapeHtml(pokemon.teraType)}</div>` : ''}
                        ${pokemon.heldItem ? `<div class="compare-row"><strong>持ち物:</strong> ${escapeHtml(pokemon.heldItem)}</div>` : ''}
                        ${pokemon.ivs ? `<div class="compare-row"><strong>個体値:</strong> ${typeof pokemon.ivs === 'object' ? Object.entries({hp:'H',atk:'A',def:'B',spa:'C',spd:'D',spe:'S'}).filter(([k])=>pokemon.ivs[k]!==undefined).map(([k,l])=>`${l}:${pokemon.ivs[k]}`).join(' / ') : (/^\d+V$/.test(pokemon.ivs) ? escapeHtml(pokemon.ivs)+'固定' : escapeHtml(pokemon.ivs))}</div>` : ''}
                        ${pokemon.evs ? `<div class="compare-row"><strong>努力値:</strong> ${escapeHtml(pokemon.evs)}</div>` : ''}
                        ${moves.length > 0 ? `<div class="compare-row"><strong>技:</strong><br>${moves.map(m => escapeHtml(m)).join('<br>')}</div>` : ''}
                        ${ribbons.length > 0 ? `<div class="compare-row"><strong>リボン:</strong><br>${ribbons.map(r => `<span class="ribbon-icon"><img src="${getRibbonImageUrl(r)}" alt="" onerror="this.style.display='none';this.nextElementSibling.style.display='inline'"><span style="display:none">${isMarkName(r) ? '🏅' : '🎀'}</span> ${escapeHtml(r)}</span>`).join(' ')}</div>` : ''}
                    </div>
                </div>
            `;
        });

        modalHtml += `
                    </div>
                    <button class="modal-bottom-close compare-bottom-close">閉じる</button>
                </div>
            </div>
        `;

        modal.innerHTML = modalHtml;
        document.body.appendChild(modal);

        const closeModal = () => modal.remove();
        modal.querySelector('.compare-modal-close').addEventListener('click', closeModal);
        modal.querySelector('.compare-bottom-close').addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });
    }

    // クリアボタンからのイベントリスナー
    window.addEventListener('clearSearch', () => {
        searchResults = allData;
        showingFavorites = false;
        showingOwned = false;
        displayedCount = 0;
        document.getElementById('showFavorites').classList.remove('active');
        document.getElementById('showOwned').classList.remove('active');
        selectedRibbons = [];
        ribbonFilterMode = 'OR';
        renderRibbonTags();
        displayResults(allData);
    });

    // リボン追加ボタン
    document.getElementById('addRibbonBtn')?.addEventListener('click', () => {
        const input = document.getElementById('filterRibbonInput');
        if (input) addRibbon(input.value);
    });

    document.getElementById('filterRibbonInput')?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
            e.preventDefault();
            addRibbon(e.target.value);
        }
    });

    // リボンモード切替
    document.querySelectorAll('input[name="ribbonMode"]').forEach(radio => {
        radio.addEventListener('change', (e) => {
            ribbonFilterMode = e.target.value;
            searchPokemon();
        });
    });

    // プリセット保存ボタン
    document.getElementById('savePresetBtn')?.addEventListener('click', () => {
        const name = prompt('プリセット名を入力してください（最大20文字）:');
        if (name && name.trim()) {
            savePreset(name.trim().slice(0, 20));
        }
    });

    // コレクション統計
    function updateCollectionStats() {
        const inner = document.getElementById('collectionStatsInner');
        if (!inner) return;
        const owned = getOwned();
        const total = allData.length;
        const ownedCount = owned.length;

        // 世代別集計
        const genGroups = {};
        allData.forEach(p => {
            const g = `第${p.generation}世代`;
            if (!genGroups[g]) genGroups[g] = { total: 0, owned: 0 };
            genGroups[g].total++;
            if (owned.includes(p.managementId)) genGroups[g].owned++;
        });

        // ゲーム別集計
        const gameGroups = {};
        allData.forEach(p => {
            const g = getGameShortName(p.game);
            if (!gameGroups[g]) gameGroups[g] = { total: 0, owned: 0 };
            gameGroups[g].total++;
            if (owned.includes(p.managementId)) gameGroups[g].owned++;
        });

        // HTML生成
        function renderGroup(title, groups) {
            const sortedEntries = Object.entries(groups).sort((a, b) => b[1].total - a[1].total);
            const rows = sortedEntries.map(([label, data]) => {
                const pct = data.total > 0 ? Math.round((data.owned / data.total) * 100) : 0;
                return `
                    <div class="stats-row">
                        <div class="stats-row-label">${escapeHtml(label)}</div>
                        <div class="stats-row-bar-wrap">
                            <div class="stats-row-bar" style="width:${pct}%"></div>
                        </div>
                        <div class="stats-row-count">${data.owned} / ${data.total}</div>
                    </div>`;
            }).join('');
            return `<div class="stats-group"><h4 class="stats-group-title">${title}</h4>${rows}</div>`;
        }

        const overallPct = total > 0 ? Math.round((ownedCount / total) * 100) : 0;
        inner.innerHTML = `
            <div class="stats-overall">
                <span class="stats-overall-label">総合</span>
                <div class="stats-row-bar-wrap">
                    <div class="stats-row-bar stats-row-bar--overall" style="width:${overallPct}%"></div>
                </div>
                <span class="stats-overall-count">${ownedCount} / ${total} (${overallPct}%)</span>
            </div>
            <div class="stats-groups">
                ${renderGroup('世代別', genGroups)}
                ${renderGroup('ゲーム別', gameGroups)}
            </div>
        `;
    }

    document.getElementById('toggleCollectionStats')?.addEventListener('click', function() {
        const panel = document.getElementById('collectionStatsPanel');
        const isHidden = panel.style.display === 'none';
        panel.style.display = isHidden ? 'block' : 'none';
        this.textContent = isHidden ? '📊 コレクション統計を閉じる' : '📊 コレクション統計を表示';
        if (isHidden) updateCollectionStats();
    });

    // 初期化
    initDarkMode();
    renderPresets();
    updateOwnedCount();
    loadData();

    // 一番上に戻るボタンの処理
    const scrollToTopBtn = document.getElementById('scrollToTop');

    window.addEventListener('scroll', () => {
        if (window.innerWidth <= 768) {
            if (window.scrollY > 300) {
                scrollToTopBtn.classList.add('show');
            } else {
                scrollToTopBtn.classList.remove('show');
            }
        }
    });

    scrollToTopBtn.addEventListener('click', () => {
        window.scrollTo({
            top: 0,
            behavior: 'smooth'
        });
    });
</script>

