---
// PokemonCard component - displays a single Pokemon distribution card
// This is a template that will be cloned by JavaScript

export interface Pokemon {
    managementId: string;
    pokemonName: string;
    shiny?: string;
    dexNo: number;
    generation: number;
    game: string;
    region?: string;
    eventName: string;
    distributionMethod: string;
    distributionLocation: string;
    startDate: string;
    endDate?: string;
    ot?: string | { JPN?: string; ENG?: string; SPA?: string; FRE?: string; GER?: string; ITA?: string; KOR?: string; CHS?: string; CHT?: string; SPA_EU?: string; SPA_LA?: string };
    trainerId?: string | number;
    ball?: string;
    level?: number;
    ability?: string;
    nature?: string;
    gigantamax?: string;
    teraType?: string;
    isAlpha?: string;
    heldItem?: string;
    ivs?: string | { hp?: number; atk?: number; def?: number; spa?: number; spd?: number; spe?: number };
    evs?: string;
    moves?: string[];
    ribbons?: string[];
    move1?: string;
    move2?: string;
    move3?: string;
    move4?: string;
    ribbon1?: string;
    ribbon2?: string;
    ribbon3?: string;
    specialMoves?: string;
    password?: string;
    notes?: string;
    postUrl?: string;
}
---

<!-- Template for Pokemon Card (hidden, used by JavaScript) -->
<template id="pokemon-card-template">
    <div class="pokemon-card">
        <input type="checkbox" class="compare-checkbox" style="display: none;">
        <div class="card-layout">
            <!-- 左側: ポケモン画像 -->
            <div class="card-image-container">
                <img class="pokemon-image" src="" alt="" loading="lazy">
                <button class="favorite-btn" title="お気に入り">☆</button>
                <button class="owned-btn" title="所持済みにする">📦</button>
                <div class="location-badge" style="display: none;"></div>
            </div>

            <!-- 右側: コンテンツ -->
            <div class="card-content">
                <div class="compact-section">
                    <div class="pokemon-header">
                        <div>
                            <span class="pokemon-name"></span>
                            <span class="dex-number"></span>
                            <span class="badges"></span>
                        </div>
                    </div>

                    <div class="info-row">
                        <div class="info-label">世代:</div>
                        <div class="info-value">
                            <span class="generation-badge"></span>
                        </div>
                    </div>

                    <div class="info-row">
                        <div class="info-label">イベント:</div>
                        <div class="info-value event-name"></div>
                    </div>

                    <div class="info-row">
                        <div class="info-label">配布期間:</div>
                        <div class="info-value">
                            <span class="distribution-period"></span>
                            <span class="distribution-status"></span>
                        </div>
                    </div>

                    <div class="info-row region-row pc-only" style="display: none;">
                        <div class="info-label">地域:</div>
                        <div class="info-value region-value"></div>
                    </div>

                    <div class="info-row pc-only">
                        <div class="info-label">配信方法:</div>
                        <div class="info-value distribution-method"></div>
                    </div>

                    <div class="info-row pc-only">
                        <div class="info-label">配信場所:</div>
                        <div class="info-value distribution-location"></div>
                    </div>

                    <div class="info-row ribbons-row pc-only" style="display: none;">
                        <div class="info-label">リボン:</div>
                        <div class="info-value">
                            <div class="ribbons"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</template>

<!-- Modal Template for Pokemon Details -->
<template id="pokemon-modal-template">
    <div class="modal-overlay">
        <div class="modal-content">
            <button class="modal-close">
                <span class="pokeball-close"></span>
            </button>
            <div class="modal-body">
                <div class="modal-header">
                    <div class="modal-header-image">
                        <img class="modal-pokemon-image" src="" alt="" loading="lazy">
                    </div>
                    <div class="modal-header-content">
                        <h2>
                            <span class="modal-pokemon-name"></span>
                        </h2>
                        <div class="modal-dex-number"></div>
                        <div class="modal-badges"></div>
                        <button class="modal-favorite-btn">☆ お気に入り登録</button>
                    </div>
                </div>

                <div class="modal-grid">
                    <div class="modal-section">
                        <h3>基本情報</h3>
                        <div class="info-row">
                            <div class="info-label">世代:</div>
                            <div class="info-value">
                                <span class="modal-generation-badge"></span>
                            </div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">イベント:</div>
                            <div class="info-value modal-event-name"></div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">配布期間:</div>
                            <div class="info-value">
                                <span class="modal-distribution-period"></span>
                                <span class="modal-distribution-status"></span>
                            </div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">配信方法:</div>
                            <div class="info-value modal-distribution-method"></div>
                        </div>
                        <div class="info-row modal-password-row" style="display: none;">
                            <div class="info-label">あいことば:</div>
                            <div class="info-value">
                                <span class="modal-password"></span>
                                <button class="password-copy-btn" title="コピー">📋</button>
                            </div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">配信場所:</div>
                            <div class="info-value modal-distribution-location"></div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">ゲーム:</div>
                            <div class="info-value modal-game"></div>
                        </div>
                        <div class="info-row modal-region-row" style="display: none;">
                            <div class="info-label">地域:</div>
                            <div class="info-value modal-region"></div>
                        </div>
                    </div>

                    <div class="modal-section">
                        <h3>ステータス</h3>
                        <div class="info-row">
                            <div class="info-label">レベル:</div>
                            <div class="info-value modal-level"></div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">特性:</div>
                            <div class="info-value modal-ability"></div>
                        </div>
                        <div class="info-row modal-nature-row" style="display: none;">
                            <div class="info-label">性格:</div>
                            <div class="info-value modal-nature"></div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">ボール:</div>
                            <div class="info-value modal-ball-status"></div>
                        </div>
                        <div class="info-row modal-tera-type-row" style="display: none;">
                            <div class="info-label">テラスタイプ:</div>
                            <div class="info-value modal-tera-type"></div>
                        </div>
                        <div class="info-row modal-item-row" style="display: none;">
                            <div class="info-label">持ち物:</div>
                            <div class="info-value">
                                <span class="modal-item-tag"></span>
                            </div>
                        </div>
                        <div class="info-row modal-ivs-row" style="display: none;">
                            <div class="info-label">個体値:</div>
                            <div class="info-value modal-ivs"></div>
                        </div>
                        <div class="info-row modal-evs-row" style="display: none;">
                            <div class="info-label">努力値:</div>
                            <div class="info-value modal-evs"></div>
                        </div>
                    </div>

                    <div class="modal-section modal-trainer-section">
                        <h3>トレーナー情報</h3>
                        <div class="info-row">
                            <div class="info-label">親名:</div>
                            <div class="info-value modal-ot"></div>
                        </div>
                        <div class="info-row modal-trainer-id-row" style="display: none;">
                            <div class="info-label">ID:</div>
                            <div class="info-value modal-trainer-id"></div>
                        </div>
                    </div>

                    <div class="modal-section modal-moves-section" style="display: none;">
                        <h3>わざ</h3>
                        <div class="modal-moves"></div>
                    </div>

                    <div class="modal-section modal-ribbons-section" style="display: none;">
                        <h3>リボン</h3>
                        <div class="modal-ribbons"></div>
                    </div>

                    <div class="modal-section modal-notes-section" style="display: none;">
                        <h3>備考</h3>
                        <div class="modal-notes"></div>
                    </div>

                    <div class="modal-section modal-memo-section">
                        <h3>📝 保管場所・メモ</h3>
                        <div class="memo-content">
                            <div class="info-row">
                                <div class="info-label">保管場所:</div>
                                <div class="info-value">
                                    <select class="memo-location-select" id="memoLocationSelect">
                                        <option value="">未設定</option>
                                        <option value="home">📱 HOME保管中</option>
                                        <option value="violet">🟣 バイオレット</option>
                                        <option value="scarlet">🔴 スカーレット</option>
                                        <option value="sword">⚔️ ソード</option>
                                        <option value="shield">🛡️ シールド</option>
                                        <option value="bdsp">💎 ダイパリメイク</option>
                                        <option value="legends">🏔️ アルセウス</option>
                                        <option value="custom">✏️ カスタム</option>
                                    </select>
                                </div>
                            </div>
                            <div class="info-row">
                                <div class="info-label">メモ:</div>
                                <div class="info-value">
                                    <textarea class="memo-custom-note" id="memoCustomNote" placeholder="例：ボックス1-5、交換用ストック3体、友人に預け中など" rows="3"></textarea>
                                </div>
                            </div>
                            <div class="memo-buttons">
                                <button class="memo-save-btn" id="memoSaveBtn">💾 保存</button>
                                <button class="memo-delete-btn" id="memoDeleteBtn">🗑️ メモ削除</button>
                            </div>
                        </div>
                    </div>

                    <div class="modal-section modal-share-section">
                        <h3>シェア</h3>
                        <div class="share-buttons">
                            <a class="share-twitter share-btn" href="" target="_blank" rel="noopener noreferrer">𝕏 ポスト</a>
                            <button class="share-copy share-btn">🔗 URLコピー</button>
                        </div>
                    </div>
                </div>

                <div class="modal-footer modal-post-url-row" style="display: none;">
                    <a class="modal-post-url-link" href="" target="_blank" rel="noopener noreferrer">詳細記事を見る</a>
                </div>

                <button class="modal-bottom-close">閉じる</button>
            </div>
        </div>
    </div>
</template>
